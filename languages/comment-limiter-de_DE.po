msgstr "Fehlermeldung bei Unterschreitung"

#: includes/class-comment-limiter-settings.php:211
msgid "Apply Settings to Admins"
msgstr "Einstellungen auf Administratoren anwenden"

#: includes/class-comment-limiter-settings.php:235
msgid "Invalid lengths. Please insert logical values."
msgstr "Ungültige Längen. Bitte geben Sie logische Werte ein."

#: includes/class-comment-limiter-settings.php:242
msgid "Maximum message error is required."
msgstr "Die Fehlermeldung bei Überschreitung ist erforderlich."

#: includes/class-comment-limiter-settings.php:248
msgid "Minimum message error is required."
msgstr "Die Fehlermeldung bei Unterschreitung ist erforderlich."

#: includes/class-comment-limiter-settings.php:255
msgid "Comment Limiter settings saved correctly."
msgstr "Comment Limiter Einstellungen wurden erfolgreich gespeichert."

#: includes/class-comment-limiter-settings.php:289
