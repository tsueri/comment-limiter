#: comment-limiter.php:65
msgid "Settings"
msgstr "Impostazioni"

#: includes/class-comment-limiter-settings.php:101
#: includes/class-comment-limiter-settings.php:102
#: includes/class-comment-limiter-settings.php:126
msgid "Comment Limiter"
msgstr "Comment Limiter"

#: includes/class-comment-limiter-settings.php:133
msgid "Save Comments Changes"
msgstr "Salva modifiche commenti"

#: includes/class-comment-limiter-settings.php:163
msgid "Maximum Characters Number"
msgstr "Numero massimo di caratteri"

#: includes/class-comment-limiter-settings.php:175
msgid "Maximum Message Error"
msgstr "Messaggio di errore massimo"

#: includes/class-comment-limiter-settings.php:187
msgid "Minimum Characters Number"
msgstr "Numero minimo di caratteri"

#: includes/class-comment-limiter-settings.php:199
msgid "Minimum Message Error"
msgstr "Messaggio di errore minimo"

#: includes/class-comment-limiter-settings.php:211
msgid "Apply Settings to Admins"
msgstr "Applica impostazioni agli amministratori"

#: includes/class-comment-limiter-settings.php:235
msgid "Invalid lengths. Please insert logical values."
msgstr "Lunghezze non valide. Inserire valori logici."

#: includes/class-comment-limiter-settings.php:242
msgid "Maximum message error is required."
msgstr "Il messaggio di errore massimo è obbligatorio."

#: includes/class-comment-limiter-settings.php:248
msgid "Minimum message error is required."
msgstr "Il messaggio di errore minimo è obbligatorio."

#: includes/class-comment-limiter-settings.php:255
msgid "Comment Limiter settings saved correctly."
msgstr "Impostazioni di Comment Limiter salvate correttamente."

#: includes/class-comment-limiter-settings.php:289
#: includes/class-comment-limiter-settings.php:298
msgid "Comment Limiter Error"
msgstr "Errore Comment Limiter"

#: includes/class-comment-limiter-settings.php:315
#: includes/class-comment-limiter-settings.php:341
msgid "Accepts only numbers"
msgstr "Accetta solo numeri"

#: includes/class-comment-limiter-settings.php:328
msgid "This is the error message that will be displayed to the user when the comment length is more than the maximum value indicated above."
msgstr "Questo è il messaggio di errore che verrà visualizzato all'utente quando la lunghezza del commento supera il valore massimo indicato sopra."

#: includes/class-comment-limiter-settings.php:354
msgid "This is the error message that will be displayed to the user when the comment length is less than the minimum value indicated above."
msgstr "Questo è il messaggio di errore che verrà visualizzato all'utente quando la lunghezza del commento è inferiore al valore minimo indicato sopra."

#: includes/class-comment-limiter-settings.php:368
msgid "Yes"
msgstr "Sì"

#: includes/class-comment-limiter-settings.php:369
msgid "No"
msgstr "No"

#: includes/class-comment-limiter-settings.php:374
msgid "This will allows users with administrator capabilities to publish comments despite the configuration of Comment Limiter plugin."
msgstr "Ciò consente agli utenti con privilegi di amministratore di pubblicare commenti nonostante la configurazione del plugin Comment Limiter."

#: includes/class-comment-limiter-settings.php:397
msgid "Your comment is too short. Minimum words: "
msgstr "Il tuo commento è troppo corto. Numero minimo di parole: "

#: includes/class-comment-limiter-settings.php:398
msgid "Your comment is too long. Maximum words: "
msgstr "Il tuo commento è troppo lungo. Numero massimo di parole: "

#: includes/class-comment-limiter-settings.php:399
msgid "Characters: %1$d of %2$d"
msgstr "Caratteri: %1$d di %2$d"

#: includes/class-comment-limiter-settings.php:401
msgid "Minimum %d characters required."
msgstr "Minimo %d caratteri richiesti."

#: includes/class-comment-limiter-settings.php:402
msgid "Maximum %d characters allowed."
msgstr "Massimo %d caratteri consentiti."